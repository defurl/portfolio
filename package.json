{
  "name": "portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "predev": "node scripts/fetch-github-activity.mjs",
    "prebuild": "node scripts/fetch-github-activity.mjs",
    "build": "tsc --noEmit && vite build",
    "postbuild": "node scripts/prerender-text-route.mjs",
    "preview": "vite preview",
    "fetch:activity": "node scripts/fetch-github-activity.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:colors": "node scripts/lint-colors.mjs",
    "bundle:check": "node scripts/bundle-budget.mjs",
    "a11y:check": "node scripts/a11y-smoke.mjs",
    "test:hooks": "node scripts/test-hooks.mjs",
    "capture:states": "node scripts/capture-states.mjs",
    "lh:check": "lhci autorun",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.0.0",
    "@fontsource/geist-sans": "^5.0.0",
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "marked": "^14.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "three": "^0.169.0",
    "tone": "^15.0.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@lhci/cli": "^0.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "@vitejs/plugin-react": "^4.3.3",
    "axe-core": "^4.10.0",
    "eslint": "^9.13.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.6",
    "playwright": "^1.48.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
